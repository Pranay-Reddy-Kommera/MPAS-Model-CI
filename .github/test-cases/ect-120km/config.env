#----------------------------------------------------------------------------
# ECT (Ensemble Consistency Test) configuration — 120km resolution
#
# Used by ect-ensemble-gen.yml and ect-test.yml workflows.
# See: Price-Broncucia et al. (2025), doi:10.5194/gmd-18-2349-2025
# PyCECT docs: https://pycect.readthedocs.io/en/latest/source/pyCECT.html
#----------------------------------------------------------------------------

# Test case data
DATA_RESOLUTION=120km
DATA_REPO=NCAR/mpas-ci-data

# Spin-up settings
# Hydrometeor fields are zero in cold-start init.nc; a 24h unperturbed
# run develops realistic values. The restart file from spin-up becomes
# the starting point for all perturbed ensemble members.
SPINUP_DURATION=1_00:00:00
SPINUP_TIMEOUT=350

# Model run settings (applied to each ensemble member, starting from restart)
# 2h36m run (13 steps at the 12-min default dt). The output stream
# output_interval is set to RUN_DURATION by run-perturb-mpas, so MPAS
# writes exactly one history file at the end of the run. The restart
# stream is disabled (output_interval="none") during ensemble runs.
RUN_DURATION=0_02:36:00
RUN_TIMEOUT=45

# PyCECT parameters
# After trimming, each history file has exactly 1 time slice (the
# end-of-run forecast), so tslice=0 reads that single slice.
ECT_TSLICE=0
ECT_ENSEMBLE_SIZE=200
ECT_TEST_RUNS=3

# Perturbation settings
# single-precision machine epsilon is ~1.2e-7
# The paper recommends 1e-14 (requires PRECISION=double).
ECT_PERTURB_MAGNITUDE=1e-14
ECT_PERTURB_VARIABLE=theta

# PyCECT version (git tag from https://github.com/NCAR/PyCECT)
PYCECT_TAG=3.3.1

# Summary file naming (uses DATA_RESOLUTION defined above)
ECT_SUMMARY_PREFIX=mpas_ect_summary_${DATA_RESOLUTION}
